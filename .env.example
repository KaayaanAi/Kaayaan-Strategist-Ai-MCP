# Kaayaan Strategist MCP - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# 🔐 SECURITY WARNING
# ============================================================================
# NEVER commit your .env file to version control!
# The .env file is in .gitignore for your protection.
# Always use environment-specific values for production deployments.

# ============================================================================
# 📊 DATABASE CONFIGURATION
# ============================================================================

# MongoDB Database Connection (Required)
# Replace with your actual MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/kaayaan_strategist

# Redis Cache Connection (Optional - improves performance)
# Replace with your actual Redis connection string  
REDIS_URL=redis://localhost:6379

# ============================================================================
# 🔑 API KEYS & AUTHENTICATION
# ============================================================================

# Alpha Vantage API Key (Optional - provides fallback data source)
# Get your free key at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day, 5 requests/minute
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ============================================================================
# ⚙️ APPLICATION CONFIGURATION
# ============================================================================

# Timezone for market analysis timestamps
# Examples: Asia/Kuwait, America/New_York, Europe/London, Asia/Tokyo
TIMEZONE=Asia/Kuwait

# Cache TTL in minutes (how long to store data in cache)
CACHE_TTL_MINUTES=15

# Environment mode
NODE_ENV=development

# ============================================================================
# 🚦 RATE LIMITING CONFIGURATION
# ============================================================================

# Yahoo Finance rate limit (requests per minute)
# Yahoo Finance is free and unlimited, but respect their servers
YAHOO_RATE_LIMIT=60

# Alpha Vantage rate limit (requests per minute)
# Free tier: 5 requests/minute, 25 requests/day
ALPHA_VANTAGE_RATE_LIMIT=5

# CoinGecko rate limit (requests per minute)
# Free tier: 50 requests/minute, 10,000-50,000 requests/month
COINGECKO_RATE_LIMIT=50

# ============================================================================
# 🌐 HTTP SERVER CONFIGURATION (Optional)
# ============================================================================

# Enable HTTP mode for REST API and web interface
# Set to 'true' to enable HTTP server alongside MCP protocol
HTTP_MODE=false

# HTTP server port
PORT=3000

# ============================================================================
# 🔍 DEBUGGING & LOGGING
# ============================================================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable detailed debugging (development only)
DEBUG=false