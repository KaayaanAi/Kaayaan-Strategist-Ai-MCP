{
  "name": "mcp-kaayaan-strategist",
  "version": "1.0.0",
  "description": "Market structure analysis and trading signals MCP server for systematic trading analysis",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "kaayaan-strategist": "./build/index.js"
  },
  "files": [
    "build/",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "prepublishOnly": "npm run build",
    "start": "node build/index.js",
    "test": "node --test tests/*.test.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "trading",
    "market-analysis",
    "technical-indicators",
    "finance",
    "claude",
    "ai",
    "rsi",
    "macd",
    "yahoo-finance",
    "mongodb",
    "redis",
    "kuwait"
  ],
  "author": "Kaayaan Strategist <info@kaayaan.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "dotenv": "^17.2.2",
    "mongodb": "^6.3.0",
    "node-fetch": "^3.3.2",
    "redis": "^4.6.12",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kaayaan/mcp-kaayaan-strategist.git"
  },
  "homepage": "https://github.com/kaayaan/mcp-kaayaan-strategist#readme",
  "bugs": {
    "url": "https://github.com/kaayaan/mcp-kaayaan-strategist/issues"
  }
}
